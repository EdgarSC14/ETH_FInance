# Dependencies
node_modules/

# Environment — keep only *.example templates in git
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
.env.test.local
!.env.example
!.env*.example

# Next.js (frontend)
frontend/.next/
frontend/out/

# Hardhat / contracts (see also contracts/.gitignore)
contracts/cache/
contracts/artifacts/
contracts/typechain-types/
contracts/deployments/*.json
!contracts/deployments/*.example.json

# Backend build output
backend/dist/

# Build output (generic)
dist/
build/
*.tsbuildinfo

# Test & E2E artifacts
coverage/
**/test-results/
**/playwright-report/
**/blob-report/
**/playwright/.cache/

# Linters
.eslintcache

# Package managers (monorepo uses pnpm-lock.yaml)
package-lock.json
yarn.lock
bun.lockb
.pnpm-store/

# Logs
*.log
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE / editor
.vscode/
.idea/
*.swp
*~

# Hosting
.vercel

# Keys and certs
*.pem
*.key
*.p12
*.pfx
