# Backend API
# Local:
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
# Vercel (frontend + backend, mismo dominio — ver docs/DEPLOYMENT.md):
# NEXT_PUBLIC_BACKEND_URL=/_/backend
#
# Producción multi-chain: tras deploy:scroll|base|… copia las 4 NEXT_PUBLIC_* del
# script y redeploya Vercel (build-time). Ver docs/DEPLOYMENT.md sección 3.

# --- Arbitrum Sepolia (421614) — defaults in constants.ts if unset ---
# NEXT_PUBLIC_VAULT_ARBITRUM_SEPOLIA=
# NEXT_PUBLIC_GOAL_MANAGER_ARBITRUM_SEPOLIA=
# NEXT_PUBLIC_PAYMENT_ROUTER_ARBITRUM_SEPOLIA=
# NEXT_PUBLIC_REPUTATION_ARBITRUM_SEPOLIA=

# --- Base Sepolia (84532) — paste from contracts/deployments/baseSepolia.json ---
# NEXT_PUBLIC_VAULT_BASE_SEPOLIA=
# NEXT_PUBLIC_GOAL_MANAGER_BASE_SEPOLIA=
# NEXT_PUBLIC_PAYMENT_ROUTER_BASE_SEPOLIA=
# NEXT_PUBLIC_REPUTATION_BASE_SEPOLIA=

# --- Scroll Sepolia (534351) — defaults in constants.ts if unset ---
# NEXT_PUBLIC_VAULT_SCROLL_SEPOLIA=0x95Df8D0A9Ff0fcB9D3a5778b7a72E231DAff8aC4
# NEXT_PUBLIC_GOAL_MANAGER_SCROLL_SEPOLIA=0x72704695cEE3fbF38EF68Ed5F849A6F4E468Dd33
# NEXT_PUBLIC_PAYMENT_ROUTER_SCROLL_SEPOLIA=0xc18d514daA63f7733850121cE02FC995197314d1
# NEXT_PUBLIC_REPUTATION_SCROLL_SEPOLIA=0xa1C7142598Cbd26135544b074D4cee04ddd61002
# MockUSDC tras deploy:scroll (obligatorio si no usas USDC de Circle en Scroll):
# NEXT_PUBLIC_USDC_SCROLL_SEPOLIA=0x...

