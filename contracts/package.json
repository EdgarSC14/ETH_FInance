{
  "name": "ethfinance-contracts",
  "version": "1.0.0",
  "description": "AI Financial Layer - Smart Contracts",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:arbitrum": "hardhat run scripts/deploy.ts --network arbitrumSepolia",
    "deploy:base": "hardhat run scripts/deploy.ts --network baseSepolia",
    "deploy:scroll": "hardhat run scripts/deploy.ts --network scrollSepolia",
    "deploy:optimism": "hardhat run scripts/deploy.ts --network optimismSepolia",
    "deploy:all-testnets": "pnpm deploy:base && pnpm deploy:scroll && pnpm deploy:optimism",
    "node": "hardhat node",
    "verify:addresses": "node scripts/verify-address-checksums.mjs"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "@types/node": "^20.0.0",
    "hardhat": "^2.22.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.0.0",
    "ethers": "^6.0.0"
  }
}
