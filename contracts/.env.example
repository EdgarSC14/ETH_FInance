# 64-character hex from MetaMask (with or without 0x). NOT your seed phrase.
DEPLOYER_PRIVATE_KEY=your-private-key-here

# RPC endpoints (defaults work if omitted)
ARBITRUM_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
BASE_SEPOLIA_RPC=https://sepolia.base.org
SCROLL_SEPOLIA_RPC=https://sepolia-rpc.scroll.io
OPTIMISM_SEPOLIA_RPC=https://sepolia.optimism.io

# Block explorer API keys (optional — for verify)
ARBISCAN_API_KEY=
BASESCAN_API_KEY=
SCROLLSCAN_API_KEY=
OPTIMISM_ETHERSCAN_API_KEY=

# Stablecoin for the target network (overrides defaults in scripts/networks.ts)
# Leave empty on local Hardhat to deploy MockUSDC.
#
